#!/usr/bin/env bash
# tanlumen — display presets for Dell U2723QE + BenQ EW3270U via BetterDisplay
# BenQ brightness is intentionally lower than Dell to match perceived luminance
#
# usage:
#   tanlumen                              # interactive picker w/ live preview
#   tanlumen <preset> [low|med|high]      # apply with optional contrast tier
#   tanlumen contrast <low|med|high>      # nudge contrast on current preset
#   tanlumen list                         # list presets
#   tanlumen current                      # show current values
#   tanlumen update [tag]                 # self-update from github releases (default: latest)
#   tanlumen version                      # print version

set -uo pipefail

VERSION="__VERSION__"

BD="${TANLUMEN_BD:-/Applications/BetterDisplay.app/Contents/MacOS/BetterDisplay}"
DELL="${TANLUMEN_DELL_TAG:-4}"
BENQ="${TANLUMEN_BENQ_TAG:-3}"
MBP="${TANLUMEN_MBP_TAG:-1}"
TAGS=("$DELL" "$BENQ" "$MBP")
STATE="$HOME/.local/state/tanlumen.last"
SNAPSHOT="$HOME/.local/state/tanlumen.snapshot"
DEBOUNCE_TOKEN="$HOME/.local/state/tanlumen.debounce"
DEBOUNCE_MS="${TANLUMEN_DEBOUNCE_MS:-1000}"
mkdir -p "$(dirname "$STATE")"

CONTRAST_MAX=0.90
# tiers set ABSOLUTE hardware DDC contrast (same for both monitors); preset values used only for color gain
TIER_LOW_C=0.20
TIER_MED_C=0.50
TIER_HIGH_C=0.80

# format: name|dell_b|dell_c|benq_b|benq_c|rGain|gGain|bGain|description
# brightness values are hardwareBrightness (real backlight 0.0–1.0)
# contrast stays near factory default (75/100 DDC); use brightness (backlight) to control eye strain
# BenQ (VA ~3000:1) needs ~0.08–0.10 lower contrast than Dell (IPS ~1000:1) at same DDC value
PRESETS=(
  "coding_day|0.85|0.75|0.70|0.64|1.00|1.00|1.00|bright office, neutral 6500K"
  "coding_evening|0.55|0.73|0.42|0.62|1.00|0.95|0.85|mixed light, mild warmth ~5500K"
  "coding_night|0.28|0.72|0.18|0.60|1.00|0.85|0.65|dark room, warm ~4000K, low strain"
  "reading|0.45|0.72|0.32|0.60|1.00|0.92|0.80|long-form text, paper-like warmth"
  "meetings|0.80|0.75|0.65|0.64|1.00|1.00|1.00|video calls, bright + neutral skin tones"
  "movies|0.55|0.80|0.40|0.70|1.00|1.00|1.00|cinema feel — dim-ish, vivid, deep blacks"
  "video|0.80|0.75|0.65|0.64|1.00|1.00|1.00|streaming/youtube — bright + neutral, vivid"
  "gaming|0.90|0.82|0.75|0.72|1.00|1.00|1.00|max brightness, punchy, full saturation"
  "design|0.70|0.75|0.55|0.64|1.00|1.00|1.00|photo/design, neutral 6500K mid"
  "deepnight|0.15|0.70|0.08|0.57|1.00|0.78|0.55|near-bed ~2700K, heavy red shift"
  "present|0.95|0.75|0.78|0.64|1.00|1.00|1.00|screen share, max clarity, vivid neutral"
)

clamp_contrast(){ LC_ALL=C awk -v v="$1" -v m="$CONTRAST_MAX" 'BEGIN{ if(v<0)v=0; if(v>m)v=m; printf "%.2f", v }'; }

tier_contrast() {
  case "$1" in
    low)  echo "$TIER_LOW_C" ;;
    high) echo "$TIER_HIGH_C" ;;
    *)    echo "$TIER_MED_C" ;;
  esac
}

apply_raw() {
  local db=$1 dc=$2 bb=$3 bc=$4 r=$5 g=$6 b=$7
  dc=$(clamp_contrast "$dc"); bc=$(clamp_contrast "$bc")
  for tag in "${TAGS[@]}"; do
    if [[ "$tag" == "$DELL" ]]; then ct=$dc; else ct=$bc; fi
    # brightness intentionally not touched — user adjusts backlight manually
    # MBP built-in has no real DDC contrast (software-gamma only) — skip contrast there
    # use hardwareContrast (real DDC) not "contrast" (BetterDisplay's combined slider
    # which mixes hardware DDC + software gamma and halves the effective panel value)
    if [[ "$tag" != "$MBP" ]]; then
      "$BD" set --feature=hardwareContrast --tagID="$tag" --value="$ct" >/dev/null 2>&1
    fi
    "$BD" set --feature=redHardwareGain    --tagID="$tag" --value="$r"  >/dev/null 2>&1
    "$BD" set --feature=greenHardwareGain  --tagID="$tag" --value="$g"  >/dev/null 2>&1
    "$BD" set --feature=blueHardwareGain   --tagID="$tag" --value="$b"  >/dev/null 2>&1
  done
}

apply_silent() {
  local target=$1 tier="${2:-med}"
  local ct; ct=$(tier_contrast "$tier")
  for p in "${PRESETS[@]}"; do
    IFS='|' read -r n db dc bb bc r g b _ <<<"$p"
    if [[ "$n" == "$target" ]]; then
      apply_raw "$db" "$ct" "$bb" "$ct" "$r" "$g" "$b"
      echo "$n|$tier" > "$STATE"
      return 0
    fi
  done
  return 1
}

# debounced silent apply — only fires if no newer focus event arrives within DEBOUNCE_MS
# fzf calls this on every focus change; rapid scrolling produces zero DDC calls,
# pausing on a row for >= DEBOUNCE_MS triggers exactly one apply
debounce_apply() {
  local target=$1 tier="${2:-med}"
  local id="$$-$RANDOM-$(date +%s%N 2>/dev/null || date +%s)"
  printf "%s|%s|%s\n" "$id" "$target" "$tier" > "$DEBOUNCE_TOKEN"
  (
    LC_ALL=C awk -v ms="$DEBOUNCE_MS" 'BEGIN{ system("sleep " ms/1000) }'
    local cur; cur=$(cat "$DEBOUNCE_TOKEN" 2>/dev/null)
    if [[ "$cur" == "$id|$target|$tier" ]]; then
      apply_silent "$target" "$tier"
    fi
  ) </dev/null >/dev/null 2>&1 &
  disown 2>/dev/null || true
}

apply_by_name() {
  local target=$1 tier="${2:-med}"
  if apply_silent "$target" "$tier"; then
    for p in "${PRESETS[@]}"; do
      IFS='|' read -r n db dc bb bc r g b desc <<<"$p"
      if [[ "$n" == "$target" ]]; then
        local ct; ct=$(clamp_contrast "$(tier_contrast "$tier")")
        echo "applied: $n [$tier] — $desc"
        echo "  contrast (both monitors): $ct   (brightness untouched — adjust manually)"
        echo "  color gain  R=$r G=$g B=$b"
        return 0
      fi
    done
  fi
  echo "unknown preset: $target" >&2
  echo "available: $(for p in "${PRESETS[@]}"; do echo -n "${p%%|*} "; done)" >&2
  return 1
}

snapshot_save() {
  {
    for tag in "${TAGS[@]}"; do
      for f in hardwareBrightness softwareBrightness contrast redHardwareGain greenHardwareGain blueHardwareGain; do
        v=$("$BD" get --feature="$f" --tagID="$tag" 2>/dev/null)
        echo "$tag $f $v"
      done
    done
  } > "$SNAPSHOT"
}

snapshot_restore() {
  [[ -f "$SNAPSHOT" ]] || return 0
  while read -r tag feat val; do
    "$BD" set --feature="$feat" --tagID="$tag" --value="$val" >/dev/null 2>&1
  done < "$SNAPSHOT"
}

list() {
  printf "%-15s %-6s %-6s %-6s %-6s %-5s %-5s %-5s  %s\n" \
    "NAME" "DELL-B" "DELL-C" "BENQ-B" "BENQ-C" "R" "G" "B" "DESCRIPTION"
  for p in "${PRESETS[@]}"; do
    IFS='|' read -r n db dc bb bc r g b desc <<<"$p"
    printf "%-15s %-6s %-6s %-6s %-6s %-5s %-5s %-5s  %s\n" \
      "$n" "$db" "$dc" "$bb" "$bc" "$r" "$g" "$b" "$desc"
  done
  echo
  echo "tiers (absolute hardware DDC contrast): low=$TIER_LOW_C, med=$TIER_MED_C, high=$TIER_HIGH_C; all presets support all tiers; brightness untouched"
  [[ -f "$STATE" ]] && echo "last applied: $(cat "$STATE")"
}

current() {
  for tag in "${TAGS[@]}"; do
    case "$tag" in
      "$DELL") label="Dell  (tag $DELL)" ;;
      "$BENQ") label="BenQ  (tag $BENQ)" ;;
      "$MBP")  label="MBP   (tag $MBP)"  ;;
      *)       label="?     (tag $tag)" ;;
    esac
    printf "%-16s  HW-B=%-5s SW-B=%-5s C=%-5s  R=%-5s G=%-5s B=%-5s\n" \
      "$label" \
      "$("$BD" get --feature=hardwareBrightness --tagID="$tag")" \
      "$("$BD" get --feature=softwareBrightness --tagID="$tag")" \
      "$("$BD" get --feature=contrast           --tagID="$tag")" \
      "$("$BD" get --feature=redHardwareGain    --tagID="$tag")" \
      "$("$BD" get --feature=greenHardwareGain  --tagID="$tag")" \
      "$("$BD" get --feature=blueHardwareGain   --tagID="$tag")"
  done
  [[ -f "$STATE" ]] && echo "last preset: $(cat "$STATE")"
}

contrast_nudge() {
  local tier=$1
  if [[ ! -f "$STATE" ]]; then
    echo "no preset applied yet — run: tanlumen <preset> first" >&2
    return 1
  fi
  local name; name=$(cut -d'|' -f1 "$STATE")
  apply_by_name "$name" "$tier"
}

pick() {
  if ! command -v fzf >/dev/null; then
    echo "fzf not found — install with: brew install fzf" >&2
    echo "or use: tanlumen <name> [low|med|high]" >&2
    list
    return 1
  fi

  snapshot_save
  local self="$0"

  local preset
  preset=$(
    for p in "${PRESETS[@]}"; do
      IFS='|' read -r n _ _ _ _ _ _ _ desc <<<"$p"
      printf "%-15s  %s\n" "$n" "$desc"
    done | fzf \
      --prompt="preset (live) > " \
      --height=60% --reverse \
      --header="step 1/2 — pause >${DEBOUNCE_MS}ms to preview, Enter to confirm, Esc to revert" \
      --bind="focus:execute-silent($self _debounce {1} med)" \
      --bind="start:execute-silent($self _apply $(echo "${PRESETS[0]}" | cut -d'|' -f1) med)"
  )
  if [[ -z "$preset" ]]; then
    snapshot_restore
    echo "cancelled — original settings restored"
    return 0
  fi
  local name="${preset%% *}"

  local tier
  tier=$(
    printf "med\nlow\nhigh\n" \
      | fzf \
        --prompt="contrast (live) > " \
        --height=30% --reverse \
        --header="step 2/2 — [$name] pause >${DEBOUNCE_MS}ms to preview, Enter to commit, Esc keeps med" \
        --preview-window="right,40%,wrap" \
        --preview='case {} in
          med)  echo "baseline contrast (0.50) — neutral, balanced" ;;
          low)  echo "soft contrast (0.20) — very flat, easy on eyes" ;;
          high) echo "punchy contrast (0.80) — deep blacks, vivid" ;;
        esac' \
        --bind="start:execute-silent($self _apply $name med)" \
        --bind="focus:execute-silent($self _debounce $name {})"
  )
  if [[ -z "$tier" ]]; then
    apply_by_name "$name" "med"
    return 0
  fi
  apply_by_name "$name" "$tier"
}

self_update() {
  local tag="${1:-latest}"
  command -v curl >/dev/null || { echo "curl is required" >&2; return 1; }
  echo "current: $VERSION"
  echo "fetching installer for tag: $tag"
  TANLUMEN_PREFIX="$(dirname "$(command -v "$0")")" \
    curl -fsSL https://raw.githubusercontent.com/tanguc/tanlumen/main/install.sh \
    | bash -s -- "$tag"
}

case "${1:-pick}" in
  list)     list ;;
  current)  current ;;
  pick)     pick ;;
  contrast) shift; contrast_nudge "${1:-med}" ;;
  update)   shift; self_update "${1:-latest}" ;;
  version|--version|-V) echo "tanlumen $VERSION" ;;
  _apply)    shift; apply_silent "$1" "${2:-med}" ;;
  _debounce) shift; debounce_apply "$1" "${2:-med}" ;;
  -h|--help)
    sed -n '2,12p' "$0"; echo; list ;;
  *)        apply_by_name "$1" "${2:-med}" ;;
esac
