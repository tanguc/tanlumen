#!/usr/bin/env bash
# tanlumen — display presets for Dell U2723QE + BenQ EW3270U via BetterDisplay
# BenQ brightness is intentionally lower than Dell to match perceived luminance
#
# usage:
#   tanlumen                              # interactive picker w/ live preview
#   tanlumen <preset> [low|med|high]      # apply with optional contrast tier
#   tanlumen contrast <low|med|high>      # nudge contrast on current preset
#   tanlumen list                         # list presets
#   tanlumen current                      # show current values
#   tanlumen version                      # print version

set -uo pipefail

VERSION="__VERSION__"

BD="${TANLUMEN_BD:-/Applications/BetterDisplay.app/Contents/MacOS/BetterDisplay}"
DELL="${TANLUMEN_DELL_TAG:-4}"
BENQ="${TANLUMEN_BENQ_TAG:-3}"
STATE="$HOME/.local/state/tanlumen.last"
SNAPSHOT="$HOME/.local/state/tanlumen.snapshot"
mkdir -p "$(dirname "$STATE")"

CONTRAST_MAX=0.90
TIER_LOW_B=-0.15;  TIER_LOW_C=-0.25
TIER_HIGH_B=0.15;  TIER_HIGH_C=0.20

# format: name|dell_b|dell_c|benq_b|benq_c|rGain|gGain|bGain|description
PRESETS=(
  "coding_day|0.85|0.78|0.70|0.72|1.00|1.00|1.00|bright office, neutral 6500K — beats ambient glare"
  "coding_evening|0.55|0.75|0.42|0.70|1.00|0.95|0.85|mixed light, mild warmth ~5500K"
  "coding_night|0.28|0.72|0.18|0.68|1.00|0.85|0.65|dark room, warm ~4000K, low strain"
  "reading|0.45|0.70|0.32|0.65|1.00|0.92|0.80|long-form text, paper-like warmth, low glare"
  "meetings|0.80|0.78|0.65|0.75|1.00|1.00|1.00|video calls, bright + neutral for accurate skin tones"
  "movies|0.55|0.85|0.40|0.82|1.00|1.00|1.00|cinema feel — dim-ish but vivid, deep blacks, neutral grade"
  "video|0.85|0.85|0.68|0.82|1.00|1.00|1.00|streaming/youtube — bright + neutral, vivid colors pop"
  "gaming|0.90|0.88|0.75|0.85|1.00|1.00|1.00|max brightness, punchy contrast, full saturation"
  "design|0.75|0.78|0.60|0.75|1.00|1.00|1.00|photo/design, factory 6500K, bright print-match"
  "deepnight|0.15|0.68|0.08|0.65|1.00|0.78|0.55|near-bed ~2700K, heavy red shift"
  "present|0.95|0.80|0.80|0.78|1.00|1.00|1.00|screen share, max clarity, vivid neutral"
)

clamp()         { LC_ALL=C awk -v v="$1" 'BEGIN{ if(v<0)v=0; if(v>1)v=1; printf "%.2f", v }'; }
clamp_contrast(){ LC_ALL=C awk -v v="$1" -v m="$CONTRAST_MAX" 'BEGIN{ if(v<0)v=0; if(v>m)v=m; printf "%.2f", v }'; }
addf()          { LC_ALL=C awk -v a="$1" -v b="$2" 'BEGIN{ printf "%.2f", a+b }'; }

tier_offsets() {
  case "$1" in
    low)  echo "$TIER_LOW_B $TIER_LOW_C" ;;
    high) echo "$TIER_HIGH_B $TIER_HIGH_C" ;;
    *)    echo "0 0" ;;
  esac
}

apply_raw() {
  local db=$1 dc=$2 bb=$3 bc=$4 r=$5 g=$6 b=$7
  dc=$(clamp_contrast "$dc"); bc=$(clamp_contrast "$bc")
  for tag in "$DELL" "$BENQ"; do
    if [[ "$tag" == "$DELL" ]]; then br=$db; ct=$dc; else br=$bb; ct=$bc; fi
    "$BD" set --feature=brightness        --tagID="$tag" --value="$br" >/dev/null 2>&1
    "$BD" set --feature=contrast          --tagID="$tag" --value="$ct" >/dev/null 2>&1
    "$BD" set --feature=redHardwareGain   --tagID="$tag" --value="$r"  >/dev/null 2>&1
    "$BD" set --feature=greenHardwareGain --tagID="$tag" --value="$g"  >/dev/null 2>&1
    "$BD" set --feature=blueHardwareGain  --tagID="$tag" --value="$b"  >/dev/null 2>&1
  done
}

apply_silent() {
  local target=$1 tier="${2:-med}"
  local bo co; read -r bo co <<<"$(tier_offsets "$tier")"
  for p in "${PRESETS[@]}"; do
    IFS='|' read -r n db dc bb bc r g b _ <<<"$p"
    if [[ "$n" == "$target" ]]; then
      apply_raw \
        "$(clamp "$(addf "$db" "$bo")")" \
        "$(addf "$dc" "$co")" \
        "$(clamp "$(addf "$bb" "$bo")")" \
        "$(addf "$bc" "$co")" \
        "$r" "$g" "$b"
      echo "$n|$tier" > "$STATE"
      return 0
    fi
  done
  return 1
}

apply_by_name() {
  local target=$1 tier="${2:-med}"
  if apply_silent "$target" "$tier"; then
    for p in "${PRESETS[@]}"; do
      IFS='|' read -r n db dc bb bc r g b desc <<<"$p"
      if [[ "$n" == "$target" ]]; then
        local bo co; read -r bo co <<<"$(tier_offsets "$tier")"
        local db2 dc2 bb2 bc2
        db2=$(clamp "$(addf "$db" "$bo")")
        dc2=$(clamp_contrast "$(addf "$dc" "$co")")
        bb2=$(clamp "$(addf "$bb" "$bo")")
        bc2=$(clamp_contrast "$(addf "$bc" "$co")")
        echo "applied: $n [$tier] — $desc"
        echo "  Dell  B=$db2 C=$dc2   gain R=$r G=$g B=$b"
        echo "  BenQ  B=$bb2 C=$bc2   gain R=$r G=$g B=$b"
        return 0
      fi
    done
  fi
  echo "unknown preset: $target" >&2
  echo "available: $(for p in "${PRESETS[@]}"; do echo -n "${p%%|*} "; done)" >&2
  return 1
}

snapshot_save() {
  {
    for tag in "$DELL" "$BENQ"; do
      for f in brightness contrast redHardwareGain greenHardwareGain blueHardwareGain; do
        v=$("$BD" get --feature="$f" --tagID="$tag" 2>/dev/null)
        echo "$tag $f $v"
      done
    done
  } > "$SNAPSHOT"
}

snapshot_restore() {
  [[ -f "$SNAPSHOT" ]] || return 0
  while read -r tag feat val; do
    "$BD" set --feature="$feat" --tagID="$tag" --value="$val" >/dev/null 2>&1
  done < "$SNAPSHOT"
}

list() {
  printf "%-15s %-6s %-6s %-6s %-6s %-5s %-5s %-5s  %s\n" \
    "NAME" "DELL-B" "DELL-C" "BENQ-B" "BENQ-C" "R" "G" "B" "DESCRIPTION"
  for p in "${PRESETS[@]}"; do
    IFS='|' read -r n db dc bb bc r g b desc <<<"$p"
    printf "%-15s %-6s %-6s %-6s %-6s %-5s %-5s %-5s  %s\n" \
      "$n" "$db" "$dc" "$bb" "$bc" "$r" "$g" "$b" "$desc"
  done
  echo
  echo "tiers: low (B-0.15, C-0.25), med (baseline), high (B+0.15, C+0.20, C-cap $CONTRAST_MAX)"
  [[ -f "$STATE" ]] && echo "last applied: $(cat "$STATE")"
}

current() {
  for tag in "$DELL" "$BENQ"; do
    label=$([ "$tag" = "$DELL" ] && echo "Dell  (tag $DELL)" || echo "BenQ  (tag $BENQ)")
    printf "%-16s  B=%-6s C=%-6s\n" \
      "$label" \
      "$("$BD" get --feature=brightness --tagID="$tag")" \
      "$("$BD" get --feature=contrast   --tagID="$tag")"
  done
  [[ -f "$STATE" ]] && echo "last preset: $(cat "$STATE")"
}

contrast_nudge() {
  local tier=$1
  if [[ ! -f "$STATE" ]]; then
    echo "no preset applied yet — run: tanlumen <preset> first" >&2
    return 1
  fi
  local name; name=$(cut -d'|' -f1 "$STATE")
  apply_by_name "$name" "$tier"
}

pick() {
  if ! command -v fzf >/dev/null; then
    echo "fzf not found — install with: brew install fzf" >&2
    echo "or use: tanlumen <name> [low|med|high]" >&2
    list
    return 1
  fi

  snapshot_save
  local self="$0"

  local preset
  preset=$(
    for p in "${PRESETS[@]}"; do
      IFS='|' read -r n _ _ _ _ _ _ _ desc <<<"$p"
      printf "%-15s  %s\n" "$n" "$desc"
    done | fzf \
      --prompt="preset (live) > " \
      --height=60% --reverse \
      --header="step 1/2 — arrow to preview LIVE, Enter to confirm, Esc to revert" \
      --bind="focus:execute-silent($self _apply {1} med)" \
      --bind="start:execute-silent($self _apply $(echo "${PRESETS[0]}" | cut -d'|' -f1) med)"
  )
  if [[ -z "$preset" ]]; then
    snapshot_restore
    echo "cancelled — original settings restored"
    return 0
  fi
  local name="${preset%% *}"

  local tier
  tier=$(
    printf "med\nlow\nhigh\n" \
      | fzf \
        --prompt="contrast (live) > " \
        --height=30% --reverse \
        --header="step 2/2 — [$name] arrow to preview, Enter to commit, Esc keeps med" \
        --preview-window="right,40%,wrap" \
        --preview='case {} in
          med)  echo "baseline contrast — the preset value as-tuned" ;;
          low)  echo "softer (B-0.15, C-0.25) — flatter, dimmer, easier on eyes" ;;
          high) echo "punchier (B+0.15, C+0.20) — brighter, deeper blacks" ;;
        esac' \
        --bind="start:execute-silent($self _apply $name med)" \
        --bind="focus:execute-silent($self _apply $name {})"
  )
  if [[ -z "$tier" ]]; then
    apply_by_name "$name" "med"
    return 0
  fi
  apply_by_name "$name" "$tier"
}

case "${1:-pick}" in
  list)     list ;;
  current)  current ;;
  pick)     pick ;;
  contrast) shift; contrast_nudge "${1:-med}" ;;
  version|--version|-V) echo "tanlumen $VERSION" ;;
  _apply)   shift; apply_silent "$1" "${2:-med}" ;;
  -h|--help)
    sed -n '2,12p' "$0"; echo; list ;;
  *)        apply_by_name "$1" "${2:-med}" ;;
esac
